# ============================================================================
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
#
# NEVER put real keys in .env.example, and NEVER commit your real .env file.
# (.env is already ignored by git — see .gitignore.)
#
# Leave these BLANK to run the app in free "mock mode" (no AI account needed).
# ============================================================================

# Where to send AI requests. Pick ONE provider's URL:
#   OpenAI  -> https://api.openai.com/v1
#   Groq    -> https://api.groq.com/openai/v1
#   Gemini  -> https://generativelanguage.googleapis.com/v1beta/openai/
AI_BASE_URL=https://api.openai.com/v1

# Your secret API key from that provider. Leave blank for mock mode.
AI_API_KEY=

# Which model to use. Examples by provider:
#   OpenAI  -> gpt-4o-mini
#   Groq    -> llama-3.3-70b-versatile
#   Gemini  -> gemini-2.0-flash
AI_MODEL=gpt-4o-mini
