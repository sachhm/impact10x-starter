# ============================================================================
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
#
# NEVER put real keys in .env.example, and NEVER commit your real .env file.
# (.env is already ignored by git — see .gitignore.)
#
# Leave AI_API_KEY BLANK to run the app in free "mock mode" (no AI account needed).
# ============================================================================

# AI Provider (OpenAI-compatible). Pick ONE provider's URL:
#   OpenAI  -> https://api.openai.com/v1
#   Groq    -> https://api.groq.com/openai/v1
#   Gemini  -> https://generativelanguage.googleapis.com/v1beta/openai/
AI_BASE_URL=https://api.openai.com/v1

# Your secret API key from that provider. Leave blank for mock mode.
AI_API_KEY=

# Which model to use. Examples by provider:
#   OpenAI  -> gpt-4o-mini
#   Groq    -> llama-3.3-70b-versatile
#   Gemini  -> gemini-2.0-flash
AI_MODEL=gpt-4o-mini

# Supabase (optional — only needed if upgrading BOX 4: MEMORY from localStorage)
# Find these in your Supabase project settings. Leave blank unless you activate
# the commented-out Supabase block in lib/memory.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
